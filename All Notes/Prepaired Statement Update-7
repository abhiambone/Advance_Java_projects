package com.sub.project;

import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.SQLException;
import java.sql.Statement;

public class Update_IN_College {

	public static void main(String[] args) throws ClassNotFoundException, SQLException {
		
		Class.forName("com.mysql.cj.jdbc.Driver");
		
		Connection conn=DriverManager.getConnection("jdbc:mysql://localhost:3306/jdbc_db_54", "root", "Password");(Put Your Password)
		
		String query="UPDATE COLLEGE SET NAME=?,BRANCH=? WHERE ROLL_NO=?";
		
		PreparedStatement ps=conn.prepareStatement(query);	
		ps.setString(1,"Madhu");
		ps.setString(2, "CS");
		ps.setInt(3, 102);
		
		int rows=ps.executeUpdate();
		conn.close();
		System.out.println("No of rows Updated is:"+rows);
		System.out.println("Data Has Been Updated Sucessfully...");
		

	}

}
